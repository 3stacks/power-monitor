# Power Monitor Configuration
# Copy to .env and adjust as needed

# Image version - pin to a specific version or use 'latest'
POWER_MONITOR_VERSION=latest

# Host port for web dashboard
WEB_PORT=3333

# Persistent data location
DATA_PATH=./data

# Target to ping (default: Google DNS)
PING_TARGET=8.8.8.8

# Ping interval in milliseconds (default: 60000 = 1 minute)
PING_INTERVAL_MS=60000

# Minimum outage duration before recording, in milliseconds
# Default: 300000 = 5 minutes (filters brief network blips)
MIN_OUTAGE_DURATION_MS=300000
